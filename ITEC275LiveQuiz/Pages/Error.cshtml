@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center mt-5">
    <h1 class="text-danger mb-4">Oops! Something went wrong.</h1>
    <p class="lead">An error occurred while processing your request.</p>
    
    <div class="mt-4">
        <a href="/" class="btn btn-primary btn-lg me-2">Go to Homepage</a>
        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg">Go Back</a>
    </div>
    
    @if (Model.ShowRequestId)
    {
        <p class="text-muted mt-4">
            <small>Request ID: <code>@Model.RequestId</code></small>
        </p>
    }
</div>
