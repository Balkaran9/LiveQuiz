@page
@model ITEC275LiveQuiz.Pages.Play.StatsModel
@{
    ViewData["Title"] = "My Stats";
}

@if (Model.Game is null || Model.Participant is null)
{
    <div class="alert alert-danger">Stats not found.</div>
}
else
{
    <div class="text-center mb-5">
        <h1 class="fw-bold mt-2">Your Performance</h1>
        <p class="lead text-muted">@Model.Game.Quiz?.Title</p>
        <p class="text-muted">Playing as <span class="badge bg-primary">@Model.Participant.Nickname</span></p>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <div class="display-5 fw-bold text-primary">@Model.Rank / @Model.TotalParticipants</div>
                    <div class="text-muted">Your Rank</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <div class="display-5 fw-bold text-success">@Model.TotalCorrect</div>
                    <div class="text-muted">Correct Answers</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <div class="display-5 fw-bold text-warning">@Math.Round((Model.TotalCorrect / (double)Math.Max(1, Model.TotalQuestions)) * 100)%</div>
                    <div class="text-muted">Accuracy</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <div class="display-5 fw-bold">@Math.Round(Model.AverageTime, 1)s</div>
                    <div class="text-muted">Avg Time</div>
                </div>
            </div>
        </div>
    </div>

    <h3 class="mb-3">Question Breakdown</h3>
    <div class="card shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Question</th>
                    <th>Your Answer</th>
                    <th>Result</th>
                    <th>Time</th>
                </tr>
            </thead>
            <tbody>
                @{ var qNum = 1; }
                @foreach (var q in Model.QuestionStats)
                {
                    <tr>
                        <td class="fw-bold">@qNum</td>
                        <td>@q.QuestionText</td>
                        <td>@q.AnswerText</td>
                        <td>
                            @if (q.IsCorrect)
                            {
                                <span class="badge bg-success">Correct</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Wrong</span>
                            }
                        </td>
                        <td>@Math.Round(q.TimeMs / 1000.0, 1)s</td>
                    </tr>
                    qNum++;
                }
            </tbody>
        </table>
    </div>

    <div class="text-center mt-5">
        <a asp-page="/Index" class="btn btn-primary btn-lg">Join Another Game</a>
    </div>
}
