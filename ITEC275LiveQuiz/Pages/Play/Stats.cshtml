@page
@model ITEC275LiveQuiz.Pages.Play.StatsModel
@{
    ViewData["Title"] = "My Stats";
}

@if (Model.Game is null || Model.Participant is null)
{
    <div class="alert alert-danger">Stats not found.</div>
}
else
{
    <div class="text-center mb-5">
        <div class="display-3">
            @(Model.Rank == 1 ? "??" : Model.Rank == 2 ? "??" : Model.Rank == 3 ? "??" : "??")
        </div>
        <h1 class="fw-bold mt-2">Your Performance</h1>
        <p class="lead text-muted">@Model.Game.Quiz?.Title</p>
        <p class="text-muted">Playing as <span class="badge bg-primary">@Model.Participant.Nickname</span></p>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <div class="display-5 fw-bold text-primary">@Model.Rank / @Model.TotalParticipants</div>
                    <div class="text-muted">Your Rank</div>
                    @if (Model.Rank == 1)
                    {
                        <div class="mt-2"><span class="badge bg-warning text-dark fs-6">?? Champion!</span></div>
                    }
                    else if (Model.Rank <= 3)
                    {
                        <div class="mt-2"><span class="badge bg-info fs-6">?? Podium Finish!</span></div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <div class="display-5 fw-bold text-success">@Model.TotalCorrect</div>
                    <div class="text-muted">Correct Answers</div>
                    @if (Model.TotalCorrect == Model.TotalQuestions && Model.TotalQuestions > 0)
                    {
                        <div class="mt-2"><span class="badge bg-success fs-6">?? Perfect Score!</span></div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <div class="display-5 fw-bold text-warning">@Math.Round((Model.TotalCorrect / (double)Math.Max(1, Model.TotalQuestions)) * 100)%</div>
                    <div class="text-muted">Accuracy</div>
                    @{
                        var accuracy = (Model.TotalCorrect / (double)Math.Max(1, Model.TotalQuestions)) * 100;
                    }
                    @if (accuracy >= 80)
                    {
                        <div class="mt-2"><span class="badge bg-success fs-6">? Excellent!</span></div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <div class="display-5 fw-bold">@Math.Round(Model.AverageTime, 1)s</div>
                    <div class="text-muted">Avg Time</div>
                    @if (Model.AverageTime < 5000)
                    {
                        <div class="mt-2"><span class="badge bg-danger fs-6">? Lightning Fast!</span></div>
                    }
                </div>
            </div>
        </div>
    </div>

    <h3 class="mb-3">Question Breakdown</h3>
    <div class="card shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Question</th>
                    <th>Your Answer</th>
                    <th>Result</th>
                    <th>Time</th>
                    <th>Points</th>
                </tr>
            </thead>
            <tbody>
                @{ var qNum = 1; }
                @foreach (var q in Model.QuestionStats)
                {
                    <tr>
                        <td class="fw-bold">@qNum</td>
                        <td>@q.QuestionText</td>
                        <td>@q.AnswerText</td>
                        <td>
                            @if (q.IsCorrect)
                            {
                                <span class="badge bg-success">? Correct</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">? Wrong</span>
                            }
                        </td>
                        <td>@Math.Round(q.TimeMs / 1000.0, 1)s</td>
                        <td class="fw-bold text-primary">@q.Points</td>
                    </tr>
                    qNum++;
                }
            </tbody>
        </table>
    </div>

    <div class="text-center mt-5">
        <a asp-page="/Index" class="btn btn-primary btn-lg">Join Another Game</a>
    </div>
}
