@page "{gameId:int?}"
@model ITEC275LiveQuiz.Pages.Play.GameModel
@{
    ViewData["Title"] = "Live Game";
}

@if (Model.Game is null)
{
    <div class="alert alert-danger">Game not found.</div>
}
else if (Model.GameEnded)
{
    <div class="waiting-screen">
        <h2 class="mt-3">Game Over!</h2>
        <p class="lead">Thanks for playing, <strong>@Model.Participant?.Nickname</strong>!</p>
        <a asp-page="Stats" asp-route-gameId="@Model.Game.LiveGameId" asp-route-participantId="@Model.Participant?.LiveParticipantId" class="btn btn-primary btn-lg mt-3 me-2">View My Stats</a>
        <a asp-page="Join" class="btn btn-outline-primary btn-lg mt-3">Join Another Game</a>
    </div>
}
else if (Model.CurrentQuestion is null)
{
    <meta http-equiv="refresh" content="4">
    <div class="waiting-screen">
        <h2>@Model.Game.Quiz?.Title</h2>
        <p class="lead text-muted">Waiting for the next question...</p>
        <p>Playing as <span class="badge bg-primary fs-6">@Model.Participant?.Nickname</span></p>
        <div class="spinner-border text-primary mt-3" role="status"><span class="visually-hidden">Loading...</span></div>
        <p class="text-muted mt-3"><small>Auto-refreshing every 4 seconds</small></p>
    </div>
}
else if (Model.AlreadyAnswered)
{
    <meta http-equiv="refresh" content="4">
    <div class="waiting-screen">
        <h2>Answer Submitted!</h2>
        <p class="lead text-muted">Waiting for the host to close the question...</p>
        <div class="spinner-border text-success mt-3" role="status"><span class="visually-hidden">Loading...</span></div>
        <p class="text-muted mt-3"><small>Auto-refreshing every 4 seconds</small></p>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="badge bg-secondary fs-6">@Model.Participant?.Nickname</span>
        <div class="timer-display" id="timer">@Model.Question?.TimeLimitSeconds</div>
    </div>

    <div class="question-card mb-4">
        <h3>@Model.Question?.QuestionText</h3>
    </div>

    <form method="post" id="answerForm">
        @Html.AntiForgeryToken()
        <input type="hidden" id="elapsedMs" value="0" />
        <input type="hidden" id="selectedAnswerId" value="0" />
        <div class="row g-3">
            @{ var idx = 0; }
            @foreach (var answer in Model.Answers)
            {
                <div class="col-md-6">
                    <button type="button"
                            class="btn answer-btn answer-btn-@(idx % 4) w-100 answer-button"
                            data-answer-id="@answer.AnswerId">
                        @answer.AnswerText
                    </button>
                </div>
                idx++;
            }
        </div>
        <div id="submitStatus" class="mt-3 text-center" style="display:none;">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Submitting your answer...</p>
        </div>
    </form>
}

@section Scripts {
    <script>
        const hasGame = @(Model.Game != null ? "true" : "false");
        const hasCurrentQuestion = @(Model.CurrentQuestion != null ? "true" : "false");
        const alreadyAnswered = @(Model.AlreadyAnswered ? "true" : "false");
        const answersCount = @Model.Answers.Count;
        const gameEnded = @(Model.GameEnded ? "true" : "false");
        
        console.log('=== PAGE LOAD STATE ===');
        console.log('Has Game:', hasGame);
        console.log('Has CurrentQuestion:', hasCurrentQuestion);
        console.log('Already Answered:', alreadyAnswered);
        console.log('Answers Count:', answersCount);
        console.log('Game Ended:', gameEnded);
        
        alert('Page State: Game=' + hasGame + ', Question=' + hasCurrentQuestion + ', Answered=' + alreadyAnswered + ', Answers=' + answersCount);
        
        const timeLimit = @(Model.Question?.TimeLimitSeconds ?? 30);
        const start = Date.now();
        const el = document.getElementById('timer');
        
        if (el) {
            const iv = setInterval(() => {
                const secs = Math.max(0, timeLimit - Math.floor((Date.now() - start) / 1000));
                el.textContent = secs;
                if (secs <= 5) el.classList.add('danger');
                if (secs === 0) {
                    clearInterval(iv);
                    console.log('Timer expired');
                }
            }, 500);
        }
        
        const buttons = document.querySelectorAll('.answer-button');
        const gameId = @(Model.Game?.LiveGameId ?? 0);
        
        alert('Found ' + buttons.length + ' answer buttons. Game ID: ' + gameId);
        
        buttons.forEach((button, index) => {
            button.addEventListener('click', async function() {
                const answerId = this.getAttribute('data-answer-id');
                const elapsedMs = Date.now() - start;
                
                alert('Button ' + (index + 1) + ' clicked! Answer ID: ' + answerId);
                console.log('Button clicked! AnswerId:', answerId, 'Elapsed:', elapsedMs);
                
                // Disable all buttons
                buttons.forEach(btn => btn.disabled = true);
                
                // Show loading
                document.getElementById('submitStatus').style.display = 'block';
                
                try {
                    const formData = new FormData();
                    formData.append('SelectedAnswerId', answerId);
                    formData.append('ElapsedMs', elapsedMs);
                    formData.append('GameId', gameId);
                    
                    const url = '/Play/Game/' + gameId;
                    alert('Sending POST to: ' + url);
                    console.log('Submitting to ' + url);
                    
                    const response = await fetch(url, {
                        method: 'POST',
                        body: formData
                    });
                    
                    alert('Response status: ' + response.status + ', OK: ' + response.ok);
                    console.log('Response status:', response.status);
                    console.log('Response OK:', response.ok);
                    
                    if (response.ok || response.redirected) {
                        alert('Success! Now redirecting to /Play/Game/' + gameId);
                        console.log('Success! Redirecting...');
                        window.location.href = '/Play/Game/' + gameId;
                    } else {
                        const text = await response.text();
                        alert('ERROR: Status ' + response.status + '. Response: ' + text.substring(0, 200));
                        console.error('Server error:', response.status);
                        console.error('Response body:', text);
                        buttons.forEach(btn => btn.disabled = false);
                        document.getElementById('submitStatus').style.display = 'none';
                    }
                } catch (error) {
                    alert('FETCH ERROR: ' + error.message);
                    console.error('Fetch error:', error);
                    buttons.forEach(btn => btn.disabled = false);
                    document.getElementById('submitStatus').style.display = 'none';
                }
            });
        });
    </script>
}
