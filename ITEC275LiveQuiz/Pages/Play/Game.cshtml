@page "{gameId:int?}"
@model ITEC275LiveQuiz.Pages.Play.GameModel
@{
    ViewData["Title"] = "Live Game";
}

@if (Model.Game is null)
{
    <div class="alert alert-danger">Game not found.</div>
}
else if (Model.GameEnded)
{
    <div class="waiting-screen">
        <h2 class="mt-3">Game Over!</h2>
        <p class="lead">Thanks for playing, <strong>@Model.Participant?.Nickname</strong>!</p>
        <a asp-page="Stats" asp-route-gameId="@Model.Game.LiveGameId" asp-route-participantId="@Model.Participant?.LiveParticipantId" class="btn btn-primary btn-lg mt-3 me-2">View My Stats</a>
        <a asp-page="Join" class="btn btn-outline-primary btn-lg mt-3">Join Another Game</a>
    </div>
}
else if (Model.CurrentQuestion is null)
{
    <meta http-equiv="refresh" content="3">
    <div class="waiting-screen">
        <h2>@Model.Game.Quiz?.Title</h2>
        <p class="lead text-muted">Waiting for the next question...</p>
        <p>Playing as <span class="badge bg-primary fs-6">@Model.Participant?.Nickname</span></p>
        <div class="spinner-border text-primary mt-3" role="status"><span class="visually-hidden">Loading...</span></div>
        <p class="text-muted mt-3"><small>Auto-refreshing every 3 seconds</small></p>
    </div>
}
else if (Model.AlreadyAnswered)
{
    <meta http-equiv="refresh" content="2">
    <div class="waiting-screen">
        <h2>Answer Submitted!</h2>
        <p class="lead text-muted">Waiting for the host to close the question...</p>
        <div class="spinner-border text-success mt-3" role="status"><span class="visually-hidden">Loading...</span></div>
        <p class="text-muted mt-3"><small>Auto-refreshing every 2 seconds</small></p>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="badge bg-secondary fs-6">@Model.Participant?.Nickname</span>
        <div class="timer-display" id="timer">@Model.Question?.TimeLimitSeconds</div>
    </div>

    <div class="question-card mb-4">
        <h3>@Model.Question?.QuestionText</h3>
    </div>

    <!-- Answer buttons screen -->
    <div id="answersDiv">
        <div class="row g-3">
            @{ var idx = 0; }
            @foreach (var answer in Model.Answers)
            {
                <div class="col-md-6">
                    <button type="button"
                            class="btn answer-btn answer-btn-@(idx % 4) w-100 answer-button"
                            data-answer-id="@answer.AnswerId"
                            style="min-height:80px; font-size:1.1rem; font-weight:700;">
                        @answer.AnswerText
                    </button>
                </div>
                idx++;
            }
        </div>
    </div>

    <!-- Answer submitted screen (hidden initially) -->
    <div id="submittedDiv" style="display:none;" class="waiting-screen">
        <h2>Answer Submitted!</h2>
        <p class="lead text-muted">Waiting for the host to close the question...</p>
        <div class="spinner-border text-success mt-3" role="status"><span class="visually-hidden">Loading...</span></div>
        <p class="text-muted mt-3"><small>Page will refresh automatically</small></p>
    </div>
}

@section Scripts {
    <script>
        const timeLimit = @(Model.Question?.TimeLimitSeconds ?? 30);
        const start = Date.now();
        const el = document.getElementById('timer');
        const gameId = @(Model.Game?.LiveGameId ?? 0);

        if (el) {
            const iv = setInterval(() => {
                const secs = Math.max(0, timeLimit - Math.floor((Date.now() - start) / 1000));
                el.textContent = secs;
                if (secs <= 5) el.classList.add('danger');
                if (secs === 0) clearInterval(iv);
            }, 500);
        }

        const buttons = document.querySelectorAll('.answer-button');

        buttons.forEach(function(button) {
            button.addEventListener('click', function() {
                const answerId = this.getAttribute('data-answer-id');
                const elapsedMs = Date.now() - start;

                // 1. IMMEDIATELY show submitted screen
                document.getElementById('answersDiv').style.display = 'none';
                document.getElementById('submittedDiv').style.display = 'block';

                // 2. Submit answer, THEN reload after confirmed
                const formData = new FormData();
                formData.append('SelectedAnswerId', answerId);
                formData.append('ElapsedMs', elapsedMs);
                formData.append('GameId', gameId);

                fetch('/Play/Game/' + gameId, {
                    method: 'POST',
                    body: formData
                }).then(function(response) {
                    console.log('POST response:', response.status);
                    // Wait 1 second after save confirmed, then reload
                    setTimeout(function() {
                        window.location.reload();
                    }, 1000);
                }).catch(function(err) {
                    console.error('Submit error:', err);
                    // Still reload even on error
                    setTimeout(function() {
                        window.location.reload();
                    }, 1000);
                });
            });
        });

        function pollForNextQuestion() {
            setTimeout(function() {
                window.location.reload();
            }, 3000);
        }
    </script>
}
