@page
@model ITEC275LiveQuiz.Pages.HelpModel
@{
    ViewData["Title"] = "Help & Instructions";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <h1 class="text-center mb-4">?? Help & Instructions</h1>

        <div class="accordion" id="helpAccordion">
            <!-- Getting Started -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#gettingStarted">
                        ?? Getting Started
                    </button>
                </h2>
                <div id="gettingStarted" class="accordion-collapse collapse show" data-bs-parent="#helpAccordion">
                    <div class="accordion-body">
                        <h5>For Players:</h5>
                        <ol>
                            <li>Get a <strong>6-character join code</strong> from your host</li>
                            <li>Click <strong>"Join Game"</strong> on the home page</li>
                            <li>Enter the code and choose a nickname</li>
                            <li>Wait for the host to start questions</li>
                            <li>Answer as fast and accurately as you can!</li>
                        </ol>

                        <h5 class="mt-3">For Hosts:</h5>
                        <ol>
                            <li><strong>Register</strong> for an account</li>
                            <li>Create a quiz and add questions with multiple-choice answers</li>
                            <li>Click <strong>"Start Game"</strong> from your quiz list</li>
                            <li>Share the join code with participants</li>
                            <li>Control question flow and view results in real-time</li>
                        </ol>
                    </div>
                </div>
            </div>

            <!-- Creating Quizzes -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#creatingQuizzes">
                        ?? Creating Quizzes
                    </button>
                </h2>
                <div id="creatingQuizzes" class="accordion-collapse collapse" data-bs-parent="#helpAccordion">
                    <div class="accordion-body">
                        <ul>
                            <li><strong>Public vs Private:</strong> Public quizzes appear in the community browse page and can be cloned by anyone</li>
                            <li><strong>Categories:</strong> Organize your quizzes by topic (Science, History, etc.)</li>
                            <li><strong>Shuffle Questions:</strong> Enable to randomize question order each game</li>
                            <li><strong>Time Limits:</strong> Set between 5-300 seconds per question</li>
                            <li><strong>Shuffle Answers:</strong> Randomize answer order for each participant</li>
                            <li><strong>Clone Feature:</strong> Copy any of your quizzes or public quizzes to modify</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Hosting Games -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#hostingGames">
                        ?? Hosting Games
                    </button>
                </h2>
                <div id="hostingGames" class="accordion-collapse collapse" data-bs-parent="#helpAccordion">
                    <div class="accordion-body">
                        <h5>Game Flow:</h5>
                        <ol>
                            <li><strong>Lobby:</strong> Wait for participants to join using the join code</li>
                            <li><strong>Open Question:</strong> Click "Open Next Question" to start a question</li>
                            <li><strong>Monitor Responses:</strong> See how many participants have answered</li>
                            <li><strong>Close Question:</strong> End the question and view results</li>
                            <li><strong>Leaderboard:</strong> Check rankings anytime during the game</li>
                            <li><strong>End Game:</strong> Finish the game and view final standings</li>
                        </ol>

                        <h5 class="mt-3">Host Tips:</h5>
                        <ul>
                            <li>The lobby auto-refreshes every 5 seconds to show new joiners</li>
                            <li>Export leaderboards to CSV for record-keeping</li>
                            <li>Check Game History to resume or review past games</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Playing Games -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#playingGames">
                        ?? Playing Games
                    </button>
                </h2>
                <div id="playingGames" class="accordion-collapse collapse" data-bs-parent="#helpAccordion">
                    <div class="accordion-body">
                        <h5>Scoring System:</h5>
                        <ul>
                            <li><strong>Base Points:</strong> 1000 points for each correct answer</li>
                            <li><strong>Speed Bonus:</strong> Up to 500 extra points for faster answers</li>
                            <li><strong>No Points:</strong> 0 points for incorrect answers</li>
                        </ul>

                        <h5 class="mt-3">Gameplay Tips:</h5>
                        <ul>
                            <li><strong>Keyboard Shortcuts:</strong> Press 1, 2, 3, or 4 to quickly select answers</li>
                            <li>Watch the countdown timer - faster answers earn more points!</li>
                            <li>The page auto-refreshes between questions</li>
                            <li>View your detailed stats at the end of the game</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Features -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#features">
                        ? Features
                    </button>
                </h2>
                <div id="features" class="accordion-collapse collapse" data-bs-parent="#helpAccordion">
                    <div class="accordion-body">
                        <h5>Host Features:</h5>
                        <ul>
                            <li>Create unlimited quizzes with custom questions</li>
                            <li>Quiz categories and tagging</li>
                            <li>Question and answer shuffling options</li>
                            <li>Real-time participant tracking</li>
                            <li>CSV export for results</li>
                            <li>Game history with resume capability</li>
                            <li>Quiz cloning (copy your own or public quizzes)</li>
                        </ul>

                        <h5 class="mt-3">Player Features:</h5>
                        <ul>
                            <li>No account required - just a nickname!</li>
                            <li>Real-time countdown timers</li>
                            <li>Keyboard shortcuts for quick play</li>
                            <li>Detailed performance stats and achievements</li>
                            <li>Points-based scoring with speed bonuses</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Troubleshooting -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#troubleshooting">
                        ?? Troubleshooting
                    </button>
                </h2>
                <div id="troubleshooting" class="accordion-collapse collapse" data-bs-parent="#helpAccordion">
                    <div class="accordion-body">
                        <h5>Common Issues:</h5>
                        <dl>
                            <dt>Can't join a game?</dt>
                            <dd>Make sure the join code is correct (6 characters) and the game is still active (Lobby or In Progress)</dd>

                            <dt>Page not updating?</dt>
                            <dd>Some pages auto-refresh, but you can always click the Refresh button manually</dd>

                            <dt>Nickname already taken?</dt>
                            <dd>Each nickname must be unique per game - try a different one!</dd>

                            <dt>Lost connection during game?</dt>
                            <dd>Hosts can check Game History to resume. Participants should rejoin using the same code and nickname.</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mt-5">
            <a asp-page="/Index" class="btn btn-primary btn-lg">Back to Home</a>
        </div>
    </div>
</div>
