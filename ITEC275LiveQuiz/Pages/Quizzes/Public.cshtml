@page
@model ITEC275LiveQuiz.Pages.Quizzes.PublicModel
@{
    ViewData["Title"] = "Public Quizzes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Public Quizzes</h1>
        <p class="text-muted mb-0">Browse quizzes shared by the community</p>
    </div>
</div>

@if (!Model.Quizzes.Any())
{
    <div class="alert alert-info">No public quizzes are available yet.</div>
}
else
{
    <div class="row g-4">
        @foreach (var quiz in Model.Quizzes)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm quiz-card">
                    <div class="card-body">
                        <h5 class="card-title">@quiz.Title</h5>
                        <p class="card-text text-muted">
                            <small>By <strong>@quiz.OwnerUser?.Username</strong></small><br />
                            <small>@quiz.Questions.Count question(s)</small><br />
                            <small>Created @quiz.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</small>
                        </p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <span class="badge bg-success">Public</span>
                        <a asp-page="Clone" asp-route-id="@quiz.QuizId" class="btn btn-sm btn-outline-primary float-end">Clone to My Quizzes</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
