@page
@model ITEC275LiveQuiz.Pages.Quizzes.Answers.CreateModel
@{
    ViewData["Title"] = "Add Answer";
}

@if (Model.Question is null)
{
    <div class="alert alert-danger">Question not found.</div>
}
else
{
    <h1>Add Answer</h1>
    <p class="text-muted">@Model.Question.QuestionText</p>

    <form method="post" class="mt-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Input.AnswerText" class="form-label"></label>
            <input asp-for="Input.AnswerText" class="form-control" />
            <span asp-validation-for="Input.AnswerText" class="text-danger"></span>
        </div>

        <div class="form-check mb-3">
            <input asp-for="Input.IsCorrect" class="form-check-input" />
            <label asp-for="Input.IsCorrect" class="form-check-label"></label>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-page="/Quizzes/Questions/Edit" asp-route-id="@Model.Question.QuestionId" class="btn btn-link">Back</a>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
