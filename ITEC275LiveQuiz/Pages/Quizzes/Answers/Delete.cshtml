@page "{id:int}"
@model ITEC275LiveQuiz.Pages.Quizzes.Answers.DeleteModel
@{
    ViewData["Title"] = "Delete Answer";
}

@if (Model.Answer is null)
{
    <div class="alert alert-danger">Answer not found.</div>
}
else
{
    <h1>Delete Answer</h1>
    <p>Are you sure you want to delete this answer?</p>
    <div class="alert alert-warning">@Model.Answer.AnswerText</div>

    <form method="post">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="/Quizzes/Questions/Edit" asp-route-id="@Model.Answer.QuestionId" class="btn btn-link">Cancel</a>
    </form>
}
