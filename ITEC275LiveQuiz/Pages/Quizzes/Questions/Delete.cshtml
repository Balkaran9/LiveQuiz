@page "{id:int}"
@model ITEC275LiveQuiz.Pages.Quizzes.Questions.DeleteModel
@{
    ViewData["Title"] = "Delete Question";
}

@if (Model.Question is null)
{
    <div class="alert alert-danger">Question not found.</div>
}
else
{
    <h1>Delete Question</h1>
    <p>Are you sure you want to delete this question?</p>
    <div class="alert alert-warning">@Model.Question.QuestionText</div>

    <form method="post">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="/Quizzes/Details" asp-route-id="@Model.Question.QuizId" class="btn btn-link">Cancel</a>
    </form>
}
