@page "{id:int}"
@model ITEC275LiveQuiz.Pages.Quizzes.DetailsModel
@{
    ViewData["Title"] = "Quiz Details";
}

@if (Model.Quiz is null)
{
    <div class="alert alert-danger">Quiz not found.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1>@Model.Quiz.Title</h1>
            <p class="text-muted mb-0">@(Model.Quiz.IsPublic ? "Public" : "Private") quiz</p>
        </div>
        <div>
            <a asp-page="Edit" asp-route-id="@Model.Quiz.QuizId" class="btn btn-outline-secondary">Edit Quiz</a>
            <a asp-page="/Host/Start" asp-route-quizId="@Model.Quiz.QuizId" class="btn btn-success">Start Game</a>
        </div>
    </div>

    <div class="mb-3">
        <a asp-page="/Quizzes/Questions/Create" asp-route-quizId="@Model.Quiz.QuizId" class="btn btn-primary">Add Question</a>
        <a asp-page="Index" class="btn btn-link">Back to My Quizzes</a>
    </div>

    @if (!Model.Quiz.Questions.Any())
    {
        <div class="alert alert-info">No questions yet.</div>
    }
    else
    {
        @foreach (var question in Model.Quiz.Questions.OrderBy(q => q.SortOrder))
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Q@question.SortOrder</strong>
                    <div>
                        <span class="badge bg-secondary me-2">@question.TimeLimitSeconds sec</span>
                        <a asp-page="/Quizzes/Questions/Edit" asp-route-id="@question.QuestionId" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-page="/Quizzes/Questions/Delete" asp-route-id="@question.QuestionId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </div>
                <div class="card-body">
                    <p>@question.QuestionText</p>
                    <ul class="list-group mb-3">
                        @foreach (var answer in question.Answers.OrderBy(a => a.AnswerId))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@answer.AnswerText</span>
                                <span>
                                    @if (answer.IsCorrect)
                                    {
                                        <span class="badge bg-success me-2">Correct</span>
                                    }
                                    <a asp-page="/Quizzes/Answers/Edit" asp-route-id="@answer.AnswerId" class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <a asp-page="/Quizzes/Answers/Delete" asp-route-id="@answer.AnswerId" class="btn btn-sm btn-outline-danger">Delete</a>
                                </span>
                            </li>
                        }
                    </ul>
                    <a asp-page="/Quizzes/Answers/Create" asp-route-questionId="@question.QuestionId" class="btn btn-sm btn-primary">Add Answer</a>
                </div>
            </div>
        }
    }
}
