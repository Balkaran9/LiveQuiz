@page
@model ITEC275LiveQuiz.Pages.Admin.StatsModel
@{
    ViewData["Title"] = "Platform Statistics";
}

<h1 class="mb-4">?? Platform Statistics</h1>
<p class="lead text-muted">Overview of LiveQuiz platform metrics</p>

<div class="row g-4 mb-5">
    <!-- Users -->
    <div class="col-lg-3 col-md-6">
        <div class="card text-center shadow-sm stat-card">
            <div class="card-body">
                <div class="display-4 text-primary">@Model.Stats.TotalUsers</div>
                <h6 class="text-muted mt-2">?? Total Users</h6>
            </div>
        </div>
    </div>

    <!-- Quizzes -->
    <div class="col-lg-3 col-md-6">
        <div class="card text-center shadow-sm stat-card">
            <div class="card-body">
                <div class="display-4 text-success">@Model.Stats.TotalQuizzes</div>
                <h6 class="text-muted mt-2">?? Total Quizzes</h6>
                <small class="text-muted">(@Model.Stats.PublicQuizzes public)</small>
            </div>
        </div>
    </div>

    <!-- Games -->
    <div class="col-lg-3 col-md-6">
        <div class="card text-center shadow-sm stat-card">
            <div class="card-body">
                <div class="display-4 text-warning">@Model.Stats.TotalGames</div>
                <h6 class="text-muted mt-2">?? Total Games</h6>
                <small class="text-success">@Model.Stats.ActiveGames active</small>
            </div>
        </div>
    </div>

    <!-- Participants -->
    <div class="col-lg-3 col-md-6">
        <div class="card text-center shadow-sm stat-card">
            <div class="card-body">
                <div class="display-4 text-info">@Model.Stats.TotalParticipants</div>
                <h6 class="text-muted mt-2">?? Total Players</h6>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Questions -->
    <div class="col-lg-3 col-md-6">
        <div class="card text-center shadow-sm stat-card">
            <div class="card-body">
                <div class="display-4 text-purple">@Model.Stats.TotalQuestions</div>
                <h6 class="text-muted mt-2">? Total Questions</h6>
            </div>
        </div>
    </div>

    <!-- Responses -->
    <div class="col-lg-3 col-md-6">
        <div class="card text-center shadow-sm stat-card">
            <div class="card-body">
                <div class="display-4 text-danger">@Model.Stats.TotalResponses</div>
                <h6 class="text-muted mt-2">? Total Responses</h6>
            </div>
        </div>
    </div>

    <!-- Avg Questions -->
    <div class="col-lg-3 col-md-6">
        <div class="card text-center shadow-sm stat-card">
            <div class="card-body">
                <div class="display-4 text-secondary">@Math.Round(Model.Stats.AverageQuestionsPerQuiz, 1)</div>
                <h6 class="text-muted mt-2">?? Avg Questions/Quiz</h6>
            </div>
        </div>
    </div>

    <!-- Avg Participants -->
    <div class="col-lg-3 col-md-6">
        <div class="card text-center shadow-sm stat-card">
            <div class="card-body">
                <div class="display-4 text-dark">@Math.Round(Model.Stats.AverageParticipantsPerGame, 1)</div>
                <h6 class="text-muted mt-2">?? Avg Players/Game</h6>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Popular Category -->
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <strong>?? Most Popular Category</strong>
            </div>
            <div class="card-body text-center">
                <h2 class="display-5 text-primary">@Model.Stats.MostPopularCategory</h2>
            </div>
        </div>
    </div>

    <!-- Top Creator -->
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <strong>?? Top Quiz Creator</strong>
            </div>
            <div class="card-body text-center">
                <h2 class="display-5 text-success">@Model.Stats.TopQuizCreator</h2>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-info text-white">
        <strong>?? Recent Activity</strong>
    </div>
    <div class="card-body">
        @if (!Model.Stats.RecentActivity.Any())
        {
            <p class="text-muted text-center">No recent activity</p>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var activity in Model.Stats.RecentActivity)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="badge bg-secondary">@activity.Type</span>
                                <span class="ms-2">@activity.Description</span>
                            </div>
                            <small class="text-muted">
                                @activity.Timestamp.ToLocalTime().ToString("MMM d, h:mm tt")
                            </small>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Completion Rate -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-warning">
        <strong>?? Game Completion Rate</strong>
    </div>
    <div class="card-body">
        @{
            var completionRate = Model.Stats.TotalGames > 0 
                ? (double)Model.Stats.CompletedGames / Model.Stats.TotalGames * 100 
                : 0;
        }
        <div class="progress" style="height: 30px;">
            <div class="progress-bar bg-success" style="width: @completionRate%">
                <strong>@Math.Round(completionRate, 1)% Complete</strong>
            </div>
        </div>
        <div class="mt-2 text-center">
            <span class="badge bg-success">@Model.Stats.CompletedGames Completed</span>
            <span class="badge bg-warning">@Model.Stats.ActiveGames Active</span>
            <span class="badge bg-secondary">@(Model.Stats.TotalGames - Model.Stats.CompletedGames - Model.Stats.ActiveGames) Other</span>
        </div>
    </div>
</div>

<div class="text-center">
    <a asp-page="/Host/Dashboard" class="btn btn-primary">Back to Dashboard</a>
</div>

<style>
    .stat-card {
        transition: all 0.3s ease;
        border: none;
    }
    .stat-card:hover {
        transform: scale(1.05);
        box-shadow: 0 10px 30px rgba(0,0,0,.2) !important;
    }
    .text-purple {
        color: #46178f;
    }
</style>
