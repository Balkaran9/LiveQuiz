@page
@model ITEC275LiveQuiz.Pages.Host.DashboardModel
@{
    ViewData["Title"] = "Host Dashboard";
}

<div class="container py-4">
    <h1 class="mb-4 fw-bold">Host Dashboard</h1>
    <div class="row g-4">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Quick Actions</h5>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <a asp-page="/Quizzes/Create" class="btn btn-primary w-100 mb-2">Create New Quiz</a>
                            <span class="text-muted small">Start building a new quiz from scratch</span>
                        </li>
                        <li class="mb-2">
                            <a asp-page="/Quizzes/Index" class="btn btn-outline-primary w-100 mb-2">My Quizzes</a>
                            <span class="text-muted small">View and manage all your quizzes</span>
                        </li>
                        <li class="mb-2">
                            <a asp-page="/Host/GameHistory" class="btn btn-outline-secondary w-100 mb-2">Game History</a>
                            <span class="text-muted small">Review past games and results</span>
                        </li>
                        <li>
                            <a asp-page="/Quizzes/Public" class="btn btn-outline-info w-100">Browse Public Quizzes</a>
                            <span class="text-muted small">Find and clone community quizzes</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-8">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Game History</h5>
                    @if (!Model.PastGames.Any())
                    {
                        <div class="alert alert-info mb-0">
                            <strong>No games yet</strong><br />
                            Start hosting quizzes to see your game history here!
                        </div>
                    }
                    else
                    {
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Quiz</th>
                                    <th>Date</th>
                                    <th>Players</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var game in Model.PastGames)
                            {
                                <tr>
                                    <td>@game.Quiz?.Title</td>
                                    <td>@game.StartedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                                    <td>@game.Participants.Count</td>
                                    <td>@game.Status</td>
                                    <td>
                                        <a asp-page="/Host/Leaderboard" asp-route-gameId="@game.LiveGameId" class="btn btn-sm btn-outline-primary">View</a>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
