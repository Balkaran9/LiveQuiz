@page "{gameId:int?}"
@model ITEC275LiveQuiz.Pages.Host.LobbyModel
@{
    ViewData["Title"] = "Host Lobby";
}

<meta http-equiv="refresh" content="5">

@if (Model.Game is null)
{
    <div class="alert alert-danger">Game not found.</div>
}
else
{
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="fw-bold">@Model.Game.Quiz?.Title</h1>
            <p class="text-muted mb-2">Share this code with players:</p>
            <div class="join-code-badge mb-3">@Model.Game.JoinCode</div>
            <p class="text-muted">
                Players join at <strong>/Play/Join</strong> &nbsp;|&nbsp;
                Questions: <strong>@Model.OpenedQuestions / @Model.TotalQuestions</strong> opened
            </p>
        </div>
        <div class="col-md-4 d-flex flex-column align-items-end gap-2">
            @if (Model.OpenLiveQuestionId.HasValue)
            {
                <a asp-page="NextQuestion" asp-route-gameId="@Model.Game.LiveGameId" class="btn btn-warning w-100">View Current Question</a>
            }
            else
            {
                <a asp-page="NextQuestion" asp-route-gameId="@Model.Game.LiveGameId" class="btn btn-success w-100">Open Next Question</a>
            }
            <a asp-page="Leaderboard" asp-route-gameId="@Model.Game.LiveGameId" class="btn btn-outline-primary w-100">Leaderboard</a>
            <a asp-page="EndGame" asp-route-gameId="@Model.Game.LiveGameId" class="btn btn-outline-danger w-100">End Game</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Players Joined</strong>
            <span class="badge bg-primary fs-6">@Model.Participants.Count</span>
        </div>
        @if (!Model.Participants.Any())
        {
            <div class="card-body text-center text-muted py-4">
                <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                Waiting for players to join...
            </div>
        }
        else
        {
            <ul class="list-group list-group-flush">
                @foreach (var p in Model.Participants)
                {
                    <li class="list-group-item">
                        @p.Nickname
                        <small class="text-muted ms-2">joined @p.JoinedAt.ToLocalTime().ToString("h:mm tt")</small>
                    </li>
                }
            </ul>
        }
    </div>
    <p class="text-muted text-center mt-2"><small>Page auto-refreshes every 5 seconds</small></p>
}
