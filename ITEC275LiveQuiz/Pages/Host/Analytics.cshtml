@page
@model ITEC275LiveQuiz.Pages.Host.AnalyticsModel
@{
    ViewData["Title"] = "Game Analytics";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Advanced Analytics</h1>
        <p class="text-muted mb-0">@Model.Game?.Quiz?.Title</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="Analytics" asp-route-gameId="@Model.Game!.LiveGameId" asp-page-handler="ExportCsv" class="btn btn-success">
            Export to CSV
        </a>
        <a asp-page="Leaderboard" asp-route-gameId="@Model.Game.LiveGameId" class="btn btn-outline-primary">
            Back to Leaderboard
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <div class="display-6 fw-bold text-primary">@Model.GameStats.TotalParticipants</div>
                <div class="text-muted">Participants</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <div class="display-6 fw-bold text-info">@Model.GameStats.TotalQuestions</div>
                <div class="text-muted">Questions</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <div class="display-6 fw-bold text-success">@Model.GameStats.AvgAccuracy.ToString("F1")%</div>
                <div class="text-muted">Avg Accuracy</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <div class="display-6 fw-bold text-warning">@Model.GameStats.AvgResponseTime.ToString("F1")s</div>
                <div class="text-muted">Avg Response Time</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Overall Performance</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <canvas id="accuracyChart" width="400" height="300"></canvas>
            </div>
            <div class="col-md-6">
                <div class="d-flex flex-column justify-content-center h-100">
                    <div class="mb-3">
                        <h6 class="text-success">Correct Responses</h6>
                        <div class="progress" style="height: 30px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: @((Model.GameStats.TotalResponses > 0 ? Model.GameStats.CorrectResponses * 100.0 / Model.GameStats.TotalResponses : 0).ToString("F1"))%">
                                @Model.GameStats.CorrectResponses (@((Model.GameStats.TotalResponses > 0 ? Model.GameStats.CorrectResponses * 100.0 / Model.GameStats.TotalResponses : 0).ToString("F1"))%)
                            </div>
                        </div>
                    </div>
                    <div>
                        <h6 class="text-danger">Incorrect Responses</h6>
                        <div class="progress" style="height: 30px;">
                            <div class="progress-bar bg-danger" role="progressbar" style="width: @((Model.GameStats.TotalResponses > 0 ? Model.GameStats.IncorrectResponses * 100.0 / Model.GameStats.TotalResponses : 0).ToString("F1"))%">
                                @Model.GameStats.IncorrectResponses (@((Model.GameStats.TotalResponses > 0 ? Model.GameStats.IncorrectResponses * 100.0 / Model.GameStats.TotalResponses : 0).ToString("F1"))%)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-info text-white">
        <h5 class="mb-0">Question-by-Question Analysis</h5>
    </div>
    <div class="card-body">
        <canvas id="questionChart" width="400" height="300"></canvas>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0">Detailed Question Statistics</h5>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Question</th>
                    <th class="text-center">Total Responses</th>
                    <th class="text-center">Correct</th>
                    <th class="text-center">Incorrect</th>
                    <th class="text-center">Accuracy</th>
                    <th class="text-center">Avg Time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stat in Model.QuestionStats)
                {
                    <tr>
                        <td>@stat.QuestionText</td>
                        <td class="text-center">@stat.TotalResponses</td>
                        <td class="text-center"><span class="badge bg-success">@stat.CorrectResponses</span></td>
                        <td class="text-center"><span class="badge bg-danger">@stat.IncorrectResponses</span></td>
                        <td class="text-center">
                            <div class="progress" style="height: 20px; min-width: 80px;">
                                <div class="progress-bar @(stat.CorrectPercentage >= 70 ? "bg-success" : stat.CorrectPercentage >= 50 ? "bg-warning" : "bg-danger")" role="progressbar" style="width: @stat.CorrectPercentage.ToString("F1")%">
                                    @stat.CorrectPercentage.ToString("F1")%
                                </div>
                            </div>
                        </td>
                        <td class="text-center">@stat.AvgTimeSeconds.ToString("F1")s</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const accuracyCtx = document.getElementById('accuracyChart').getContext('2d');
        new Chart(accuracyCtx, {
            type: 'pie',
            data: {
                labels: ['Correct', 'Incorrect'],
                datasets: [{
                    data: [@Model.GameStats.CorrectResponses, @Model.GameStats.IncorrectResponses],
                    backgroundColor: ['#28a745', '#dc3545']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    title: {
                        display: true,
                        text: 'Overall Accuracy Distribution',
                        font: { size: 16 }
                    },
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        const questionCtx = document.getElementById('questionChart').getContext('2d');
        new Chart(questionCtx, {
            type: 'bar',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.QuestionStats.Select((q, i) => $"'Q{i + 1}'")))],
                datasets: [
                    {
                        label: 'Correct',
                        data: [@string.Join(",", Model.QuestionStats.Select(q => q.CorrectResponses))],
                        backgroundColor: '#28a745'
                    },
                    {
                        label: 'Incorrect',
                        data: [@string.Join(",", Model.QuestionStats.Select(q => q.IncorrectResponses))],
                        backgroundColor: '#dc3545'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                scales: {
                    x: {
                        stacked: false
                    },
                    y: {
                        stacked: false,
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1
                        }
                    }
                },
                plugins: {
                    title: {
                        display: true,
                        text: 'Correct vs Incorrect Responses by Question',
                        font: { size: 16 }
                    },
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    </script>
}
